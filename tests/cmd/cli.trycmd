Command: 'rsync' '-a' '--stats' '--dry-run' '-z' '--exclude-from' '[excludes-file]' 'deploy@staging.example.com:/var/www/movepress/wp-content/' '[CWD]/tests/fixtures/local/wp-content/'
Excludes: **/*.log, **/.DS_Store, wp-content/uploads/cache/**

$ env PATH="$PWD/tests/fixtures/bin:$PATH" movepress push db local staging --yes --config tests/cmd/fixtures/local-db.toml
Auto-confirmed database operation for non-production target 'staging'.

